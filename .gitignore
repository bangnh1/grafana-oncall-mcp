/grafana-oncall-mcp

# Build / install output directories
/bin/
/dist/

# Profiling / debug output
*.prof
*.pprof

# --- Go coverage ---
coverage.out
coverage.html

# --- Go workspace / tooling scratch ---
go.work
go.work.sum

# --- IDE / editor ---
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# --- OS files ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Environment & secrets ---
.env
.env.*
!.env.example
*.key
*.crt
*.pem

# --- Local logs / runtime data ---
*.log
logs/

# --- Spec-kit & opencode tooling (not part of the project source) ---
.opencode/
.specify/
bin/