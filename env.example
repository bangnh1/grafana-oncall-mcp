# =============================================================================
# grafana-oncall-mcp — environment configuration template
# =============================================================================
# Copy this file to `.env` (or to any path the operator prefers) and
# fill in the values that match your Grafana instance. All variables
# are required unless marked [OPT].
#
#   cp env.example .env
#   $EDITOR .env
#
# The Grafana connection variables (GRAFANA_URL, GRAFANA_SERVICE_ACCOUNT_TOKEN
# / GRAFANA_API_KEY) are read by the MCP server binary directly. The
# MCP_* variables control the docker-compose deployment shape (port
# mapping, health probe, transport choice). Both are listed here so
# a single file carries the full deployment config.
# =============================================================================

# -----------------------------------------------------------------------------
# Grafana connection
# -----------------------------------------------------------------------------

# Base URL of the target Grafana instance. HTTPS is enforced by the
# MCP server for non-localhost hosts (FR-052); use http://localhost
# or http://127.0.0.1 only for self-hosted dev stacks.
# Examples:
#   GRAFANA_URL=https://myorg.grafana.net
#   GRAFANA_URL=http://localhost:3000
GRAFANA_URL=

# Grafana service-account token (preferred). Generate one under
# Grafana -> Administration -> Service accounts. The token needs
# OnCall read scope; add the write scopes (alert-groups:acknowledge,
# alert-groups:resolve, alert-groups: silence, alert-groups:unresolve)
# only if you intend to expose the write tools.
GRAFANA_SERVICE_ACCOUNT_TOKEN=

# Legacy Grafana API key. Use this ONLY if your Grafana is too old
# to support service accounts (Grafana < 9.1). If both this and
# GRAFANA_SERVICE_ACCOUNT_TOKEN are set, the service-account token
# wins.
# GRAFANA_API_KEY=

# Direct OnCall API mode.
# Use this when you want to call the OnCall Application API directly,
# bypassing Grafana's plugin resource proxy. This is especially useful
# for legacy grafana-oncall-app deployments where a Grafana service
# account token resolves to a user like `sa-...` that OnCall cannot
# find.
#
# Get these values from OnCall -> Settings:
#   GRAFANA_ONCALL_API_URL = the "OnCall Application endpoint"
#   GRAFANA_ONCALL_API_KEY = the user-scoped "API key"
#
# When both are set, GRAFANA_URL and GRAFANA_SERVICE_ACCOUNT_TOKEN
# are not required.
# GRAFANA_ONCALL_API_URL=https://oncall-prod-us-central-0.grafana.net/oncall
# GRAFANA_ONCALL_API_KEY=

# -----------------------------------------------------------------------------
# Dual-plugin auto-detection (spec 002-multi-plugin-support)
# -----------------------------------------------------------------------------

# Force plugin selection when both `grafana-oncall-app` and
# `grafana-irm-app` are installed. Accepted values:
#   oncall-app   — legacy plugin (default when unset)
#   irm          — rebranded plugin
# (empty)        — auto-detect: prefer oncall-app when both are
#                  installed, fall through to whichever is installed
#                  when only one is, fail with ONCALL_PLUGIN_MISSING
#                  when neither is.
# GRAFANA_ONCALL_PLUGIN_PREFERENCE=oncall-app

# -----------------------------------------------------------------------------
# Read-only mode (FR-024)
# -----------------------------------------------------------------------------

# When true, all write tools (acknowledge/resolve/silence/unresolve)
# are omitted from the MCP tool list. Recommended for incident
# assistants that should not be able to mutate state.
# GRAFANA_ONCALL_READ_ONLY=false

# -----------------------------------------------------------------------------
# HTTP client tuning
# -----------------------------------------------------------------------------

# Per-request outbound HTTP timeout (Go duration syntax).
# GRAFANA_ONCALL_HTTP_TIMEOUT=10s

# Max retries on transient upstream failures (HTTP 429 / 5xx).
# GRAFANA_ONCALL_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------

# Log level: debug | info | warn | error. Set to debug for verbose
# HTTP request/response logging.
# LOG_LEVEL=info

# OpenTelemetry OTLP endpoint. When set, the server emits traces
# and metrics to this collector. Empty by default.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# -----------------------------------------------------------------------------
# docker-compose deployment shape
# -----------------------------------------------------------------------------

# Image tag for `docker compose build`. Override when publishing
# images to a registry.
# IMAGE_TAG=local

# Port the streamable-HTTP / SSE server binds to inside the
# container AND on the host. The default 8000 matches the
# upstream mcp-grafana convention.
# MCP_PORT=8000

# Streamable-HTTP endpoint path. Default /mcp matches the official
# MCP spec; some clients expect / or /mcp/legacy — adjust to taste.
# MCP_ENDPOINT_PATH=/mcp

# SSE base path. Default /sse matches the upstream mcp-grafana
# convention.
# MCP_BASE_PATH=/sse

# When true, the HTTP service also exposes a /metrics endpoint
# on the same port (Prometheus text format).
# METRICS=false
